#include <dt-bindings/zmk/keys.h>
/ {
    input_processors {
        /* This converts vertical scroll ticks into volume keystrokes */
        zip_scroll_to_volume: zip_scroll_to_volume {
            compatible = "zmk,input-processor-behaviors";
            #input-processor-cells = <0>;
            
            /* We use the wheel code twice to match the two bindings */
            codes = <INPUT_REL_WHEEL>, <INPUT_REL_WHEEL>;
            
            /* Binding 1: Positive movement (Scroll Up) -> Volume Up */
            /* Binding 2: Negative movement (Scroll Down) -> Volume Down */
            bindings = <&kp C_VOL_UP>, <&kp C_VOL_DN>;
        };
    };

    input_listener_unibody0: input_listener_unibody0 {
        compatible = "zmk,input-listener";
        status = "okay";
        device = <&input_split_unibody0>;

        /* Volume logic only active on Layer 1 */
        scroll_volume {
            layers = <1>; 
            input-processors = <
                &zip_xy_to_scroll_mapper
                &zip_scroll_scaler 1 32
                &zip_scroll_to_volume
            >;
        };
    };
};
