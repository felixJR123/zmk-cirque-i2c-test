#include <dt-bindings/zmk/keys.h>
/ {
    input_processors {
        zip_scroll_to_volume: zip_scroll_to_volume {
            compatible = "zmk,input-processor-code-mapper";
            #input-processor-cells = <0>;
            /* Listen for the Scroll Wheel signal created by the mapper below */
            type = <INPUT_EV_REL>, <INPUT_EV_REL>;
            /* First binding = Scroll Up (Vol Up), Second = Scroll Down (Vol Down) */
            map = <INPUT_BTN_DPAD_UP INPUT_KEY_VOLUMEUP>, <INPUT_BTN_DPAD_DOWN INPUT_KEY_VOLUMEDOWN>;
        };
    };

    input_listener_unibody0: input_listener_unibody0 {
        compatible = "zmk,input-listener";
        status = "okay";
        device = <&input_split_unibody0>;
        
        /* Move processors here to ensure they catch all events */
        input-processors = <
            &zip_xy_to_scroll_mapper
            &zip_scroll_scaler 1 32
            &zip_scroll_to_volume
        >;
    };
};
