#include "cirquei2ctest-layouts.dtsi"
#include <input/processors.dtsi>
#include <dt-bindings/zmk/input_transform.h>
#include <dt-bindings/zmk/matrix_transform.h>
#include <physical_layouts.dtsi>
#include <zephyr/dt-bindings/input/input-event-codes.h>


/ {
    matrix_transform0: matrix_transform0 {
        compatible = "zmk,matrix-transform";
        columns = <1>;
        rows = <1>;
        map = <
            RC(0,0)
        >;
    };
};

&physical_layout_cirquei2ctest {
    transform = <&matrix_transform0>;
};

// Input devices
/ {
    split_inputs {
        #address-cells = <1>;
        #size-cells = <0>;

        input_split_unibody0: input_split_unibody0@0 {
            compatible = "zmk,input-split";
            reg = <0>;
            status = "disabled";
        };
    };

//     input_listener_unibody0: input_listener_unibody0 {
//         compatible = "zmk,input-listener";
//         status = "disabled";
//         device = <&input_split_unibody0>;
//     };
 };

#include <dt-bindings/zmk/keys.h>
/ {
    input_processors {
        scroll_to_volume: scroll_to_volume {
            compatible = "zmk,input-processor-behaviors";
            #input-processor-cells = <0>;

            /* One code, two directions handled internally */
            codes = <INPUT_REL_WHEEL>;

            /* First = positive, Second = negative */
            bindings = <&kp C_VOL_UP>, <&kp C_VOL_DN>;
        };
    };

    input_listener_unibody0: input_listener_unibody0 {
        compatible = "zmk,input-listener";
        status = "okay";
        device = <&input_split_unibody0>;

        scroll_volume {
            layers = <1>;
            input-processors = <
                &zip_xy_to_scroll_mapper
                &zip_scroll_scaler 1 32
                &scroll_to_volume
            >;
        };
    };
};
